# This is a complete local development environment file
# Copy this to packages/backend/.env and packages/frontend/.env

# Backend Environment Variables (packages/backend/.env)
DATABASE_URL=postgresql://lconn:lconn_dev@localhost:5432/lconn
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here
GITHUB_CALLBACK_URL=http://localhost:3001/api/auth/github/callback
SESSION_SECRET=change_this_to_a_random_string_in_production
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Frontend Environment Variables (packages/frontend/.env)
VITE_API_URL=http://localhost:3001
